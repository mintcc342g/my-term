{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.env.local)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/.env.local)",
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(**/secrets/**)",
      "Edit(**/secrets/**)",
      "Read(**/.credentials*)",
      "Edit(**/.credentials*)",
      "Read(**/.secret*)",
      "Edit(**/.secret*)",
      "Read(**/*.pem)",
      "Edit(**/*.pem)",
      "Read(**/*.key)",
      "Edit(**/*.key)",
      "Read(**/.aws/**)",
      "Edit(**/.aws/**)",
      "Read(**/.gcp/**)",
      "Edit(**/.gcp/**)",
      "Read(**/.kube/config)",
      "Edit(**/.kube/config)",
      "Read(**/.codex/auth.json)",
      "Edit(**/.codex/auth.json)",
      "Read(**/.codex/sessions/**)",
      "Edit(**/.codex/sessions/**)",
      "Read(**/.zprofile)",
      "Edit(**/.zprofile)",
      "Read(**/.zshrc)",
      "Edit(**/.zshrc)",
      "Read(**/.zsh_history)",
      "Edit(**/.zsh_history)",
      "Read(**/.npmrc)",
      "Edit(**/.npmrc)",
      "Read(**/.pypirc)",
      "Edit(**/.pypirc)",
      "Read(**/.netrc)",
      "Edit(**/.netrc)",
      "Read(**/.docker/config.json)",
      "Edit(**/.docker/config.json)",
      "Read(**/.config/gh/hosts.yml)",
      "Edit(**/.config/gh/hosts.yml)",
      "Read(**/.git-credentials)",
      "Edit(**/.git-credentials)",
      "Read(**/.gnupg/**)",
      "Edit(**/.gnupg/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/.env.local)",
      "Write(~/.ssh/**)",
      "Write(**/secrets/**)",
      "Write(**/.credentials*)",
      "Write(**/.secret*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/.aws/**)",
      "Write(**/.gcp/**)",
      "Write(**/.kube/config)",
      "Write(**/.codex/auth.json)",
      "Write(**/.codex/sessions/**)",
      "Write(**/.zprofile)",
      "Write(**/.zshrc)",
      "Write(**/.zsh_history)",
      "Write(**/.npmrc)",
      "Write(**/.pypirc)",
      "Write(**/.netrc)",
      "Write(**/.docker/config.json)",
      "Write(**/.config/gh/hosts.yml)",
      "Write(**/.git-credentials)",
      "Write(**/.gnupg/**)",
      "Bash(**/.env)",
      "Bash(**/.env.*)",
      "Bash(**/.env.local)",
      "Bash(**/.ssh/**)",
      "Bash(**/secrets/**)",
      "Bash(**/.credentials*)",
      "Bash(**/.secret*)",
      "Bash(**/*.pem)",
      "Bash(**/*.key)",
      "Bash(**/.aws/**)",
      "Bash(**/.gcp/**)",
      "Bash(**/.kube/config)",
      "Bash(**/.codex/auth.json)",
      "Bash(**/.zsh_history)",
      "Bash(**/.npmrc)",
      "Bash(**/.pypirc)",
      "Bash(**/.netrc)",
      "Bash(**/.docker/config.json)",
      "Bash(**/.config/gh/hosts.yml)",
      "Bash(**/.git-credentials)",
      "Bash(**/.gnupg/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/my-hud/statusline.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "zsh $HOME/.claude/my-hooks/init-env.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/my-hooks/init-env-bg.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "@co",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/my-collab/codex-collab.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/my-hud/protect-statusline.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/my-hud/prune-claude-hud-cache.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
